def minimumContainers(weights, capacity):

    weights.sort(reverse=True)

    containers = 1
    current = 0

    for w in weights:

        if current + w <= capacity:
            current += w

        else:
            containers += 1
            current = w

    return containers


print(minimumContainers([5,10,15,20,25,30,35],50))

print(minimumContainers([10,20,30,40,50,60,70,80],100))
