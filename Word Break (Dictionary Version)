dictionary = {
    "i","like","sam","sung","samsung",
    "mobile","ice","cream","icecream",
    "man","go","mango"
}

def wordBreakDictionary(s):

    dp = [False]*(len(s)+1)
    dp[0] = True

    for i in range(1, len(s)+1):
        for j in range(i):
            if dp[j] and s[j:i] in dictionary:
                dp[i] = True
                break

    return dp[-1]


print(wordBreakDictionary("ilike"))
print(wordBreakDictionary("ilikesamsung"))
