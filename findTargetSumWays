def findTargetSumWays(nums, target):

    count = 0

    def dfs(index, total):
        nonlocal count

        if index == len(nums):
            if total == target:
                count += 1
            return

        dfs(index + 1, total + nums[index])
        dfs(index + 1, total - nums[index])

    dfs(0, 0)

    return count


print(findTargetSumWays([1,1,1,1,1],3))
print(findTargetSumWays([1],1))
